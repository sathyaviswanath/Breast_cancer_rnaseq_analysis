library(DESeq2)
q()
colnames(counts)
counts <- read.table("counts/clean_counts.txt", header=TRUE, row.names=1)
coldata <- read.table("counts/metadata.txt", header=TRUE, row.names=1)
colnames(counts)
rownames(coldata)
colnames(counts) <- gsub("aligned.", "", colnames(counts))
colnames(counts) <- gsub("_sorted.bam", "", colnames(counts))
colnames(counts)
rownames(coldata)
dds <- DESeqDataSetFromMatrix(
    countData = counts,
    colData = coldata,
    design = ~ condition
)
library(DESeq2)
dds <- DESeqDataSetFromMatrix(
    countData = counts,
    colData = coldata,
    design = ~ condition
)
coldata$condition <- as.factor(coldata$condition)
str(coldata)
dds <- DESeqDataSetFromMatrix(
    countData = counts,
    colData = coldata,
    design = ~ condition
)
dds <- DESeq(dds)
res <- results(dds)
head(res)
write.csv(as.data.frame(res), file="counts/deseq2_results.csv")
nrow(res)
res_df <- as.data.frame(res)
res_sig <- res_df[which(res_df$padj < 0.05 & abs(res_df$log2FoldChange) > 1), ]
nrow(res_sig)
res_sig <- res_df[which(res_df$padj < 0.1), ]
nrow(res_sig)
res_sig <- res_df[which(res_df$pvalue < 0.05), ]
nrow(res_sig)
write.csv(res_sig, file="counts/significant_genes.csv")
library(ggplot2)
res_df$significance <- "Not Significant"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange > 1] <- "Upregulated"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange < -1] <- "Downregulated"
ggplot(res_df, aes(x=log2FoldChange, y=-log10(pvalue), color=significance)) +
  geom_point(alpha=0.6) +
  scale_color_manual(values=c("blue","grey","red")) +
  theme_minimal() +
  ggtitle("Differential Gene Expression - Volcano Plot") +
  xlab("Log2 Fold Change") +
  ylab("-log10(p-value)")
vsd <- vst(dds)
plotPCA(vsd, intgroup="condition")
library(pheatmap)
topgenes <- head(order(res$pvalue), 20)
mat <- assay(vsd)[topgenes, ]
pheatmap(mat, scale="row")
ggsave("counts/volcano_plot.png")
png("counts/pca_plot.png")
plotPCA(vsd, intgroup="condition")
dev.off()
png("counts/heatmap.png")
pheatmap(mat, scale="row")
dev.off()
q()
library(pheatmap)
topgenes <- head(order(res$pvalue), 20)
mat <- assay(vsd)[topgenes, ]
pheatmap(mat, scale="row")
png("counts/heatmap.png")
pheatmap(mat, scale="row")
dev.off()
q()
library(DESeq2)
library(ggplot2)

res_df <- as.data.frame(res)

res_df$significance <- "Not Significant"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange > 1] <- "Up"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange < -1] <- "Down"

volcano_plot <- ggplot(res_df, aes(x=log2FoldChange, y=-log10(pvalue), color=significance)) +
  geom_point(alpha=0.6) +
  scale_color_manual(values=c("blue","grey","red")) +
  theme_minimal() +
  ggtitle("Volcano Plot")
library(ggplot2)

res_df <- as.data.frame(res)

res_df$significance <- "Not Significant"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange > 1] <- "Up"
res_df$significance[res_df$pvalue < 0.05 & res_df$log2FoldChange < -1] <- "Down"

volcano_plot <- ggplot(res_df, aes(x=log2FoldChange, y=-log10(pvalue), color=significance)) +
  geom_point(alpha=0.6) +
  scale_color_manual(values=c("blue","grey","red")) +
  theme_minimal() +
  ggtitle("Volcano Plot")
print(volcano_plot)
ggsave("counts/volcano_plot_final.png", plot = volcano_plot, width = 8, height = 6, dpi = 300)
q()
